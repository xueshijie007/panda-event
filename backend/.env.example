# Optional. Defaults to backend/simulator.db when omitted.
DATABASE_URL=sqlite:///./simulator.db

# exchange: try Binance first, fallback to mock on failure.
# mock: skip external exchange APIs and always generate local mock Klines.
MARKET_DATA_MODE=exchange

# Lower timeout makes fallback faster when exchange APIs are slow/unreachable.
MARKET_HTTP_TIMEOUT=2.0

# Comma-separated frontend origins for browser CORS. Default allows localhost Vite dev server.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
